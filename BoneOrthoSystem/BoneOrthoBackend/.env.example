OPENAI_API_KEY=請填入有效 OpenAI API Key
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=bone_edu_docs
EMBEDDING_DIM=1536
QDRANT_DEBUG=1
QDRANT_QUERY_SCORE_THRESHOLD=0.10
QDRANT_ENABLE_GIBBERISH_FILTER=0
QDRANT_EXCLUDE_PLACEHOLDERS=0
S1_YOLO_MODEL_PATH=./s1_detection/model/best.pt
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# 開發用：不真的寄信
EMAIL_MODE=console
EMAIL_OTP_SECRET=dev-secret-change-me
EMAIL_OTP_TTL_MINUTES=15
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
# 真的要寄信
# EMAIL_MODE=smtp
# EMAIL_OTP_SECRET=prod-secret-change-me
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=GalaBone <your_email@gmail.com>
# 上傳時自動索引（有索引，聊天才找得到 chunks）
S2_ENABLE_DOC_RAG=1
S2_DOC_RAG_INDEX_ON_UPLOAD=1
S2_DOC_RAG_INDEX_ON_URL=1
# 聊天時啟用文件型 RAG（會走 answer_with_doc_rag）
S2_URL_TIMEOUT=15
S2_URL_MAX_BYTES=2000000
SOAP_CSV_PATH=s2_agent/data/soap_records.csv
SOAP_ID_COL=RRN
SOAP_DATE_COL=就診日期
SOAP_SUBJECTIVE_COL=SUBJCONTENT
SOAP_OBJECTIVE_COL=OBJECONTENT
SOAP_ASSESSMENT_COL=ASSECONTENT
SOAP_PLAN_COL=PLANCONTENT
